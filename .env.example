# Mailgun (leave empty to use console email backend — logs emails to stdout)
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_API_KEY=key-xxxxxxxx
MAILGUN_FROM=noreply@yourdomain.com
MAILGUN_API_BASE=https://api.mailgun.net/v3  # use https://api.eu.mailgun.net/v3 for EU

# Optional (increases GitHub rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=

# Optional (API key authentication, disabled if empty)
API_KEY=

# Debug mode (enables DEBUG logging + console email backend)
DEBUG=false

# CORS (set to your frontend domain in production, e.g. https://releases.yoursite.com)
CORS_ORIGINS=*

# Optional overrides
# SCAN_INTERVAL=5m
# NOTIFICATION_WORKERS=10
# BASE_URL=http://localhost:8080
