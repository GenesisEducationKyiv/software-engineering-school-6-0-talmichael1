# Required when running the binary outside Docker.
# docker-compose.yml sets this in the `environment:` block, so
# you can leave it blank when using `docker compose up`.
# DATABASE_URL=postgres://notifier:notifier@localhost:5432/release_notifier?sslmode=disable

# Mailgun (leave empty to use console email backend — logs emails to stdout)
MAILGUN_DOMAIN=
MAILGUN_API_KEY=
MAILGUN_FROM=
MAILGUN_API_BASE=  # use https://api.eu.mailgun.net/v3 for EU

# Optional (increases GitHub rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=

# Optional (API key authentication, disabled if empty)
API_KEY=

# Debug mode (enables DEBUG logging + console email backend)
DEBUG=false

# CORS (set to your frontend domain in production, e.g. https://releases.yoursite.com)
CORS_ORIGINS=*

# Optional overrides
# SCAN_INTERVAL=5m
# SCAN_WORKERS=5
# NOTIFICATION_WORKERS=10
# BASE_URL=http://localhost:8080
